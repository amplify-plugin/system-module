{
    "name": "amplify/system",
    "description": "This is a System module for amplify",
    "type": "library",
    "license": "GPL-3.0-or-later",
    "authors": [
        {
            "name": "Hafijul Islam",
            "email": "hafijul.islam@easyask.com",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.3",
        "ext-curl": "*",
        "ext-dom": "*",
        "ext-gd": "*",
        "ext-json": "*",
        "ext-libxml": "*",
        "ext-mbstring": "*",
        "ext-pdo": "*",
        "ext-simplexml": "*",
        "ext-zip": "*",
        "amplify/backend": "*",
        "amplify/cms": "*",
        "amplify/custom-item": "*",
        "amplify/erp": "*",
        "amplify/frontend": "*",
        "amplify/message": "*",
        "amplify/order-rule": "*",
        "amplify/sayt": "*",
        "amplify/ticket": "*",
        "amplify/utility": "*",
        "backpack/crud": "^7.0",
        "backpack/editable-columns": "^3.1",
        "backpack/pro": "^3.0",
        "consoletvs/charts": "^6.9",
        "cviebrock/eloquent-sluggable": "^12.0",
        "intervention/image": "^4.1",
        "laraflow/form": "^0.2.0",
        "laravel/framework": "^12.0",
        "league/flysystem": "^3.35",
        "league/flysystem-aws-s3-v3": "^3.35",
        "maatwebsite/excel": "^3.1",
        "owen-it/laravel-auditing": "^14.0",
        "spatie/laravel-health": "^1.40",
        "spatie/laravel-honeypot": "^4.7",
        "spatie/laravel-permission": "^8.3",
        "spatie/laravel-translatable": "^6.14"
    },
    "autoload": {
        "psr-4": {
            "Amplify\\System\\": "./src"
        },
        "files": [
            "./src/helpers.php"
        ]
    },
    "extra": {
        "laravel": {
            "providers": [
                "Amplify\\System\\SystemServiceProvider"
            ],
            "aliases": {
                "Assets": "Amplify\\System\\Facades\\AssetsFacade",
                "Captcha": "Amplify\\System\\Facades\\CaptchaFacade"
            }
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "suggest": {
        "ext-pcntl": "For Linux with Ext. PCNTL enabled for parallel process.",
        "league/flysystem-ftp": "^3.28 To allow amplify to push database to easyask."
    }
}
